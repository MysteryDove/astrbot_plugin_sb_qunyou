{
  "Debounce_Settings": {
    "type": "object",
    "items": {
      "mode": {
        "description": "消息防抖模式：off=关闭, time=仅时间窗口, time_bert=时间+语义完整性",
        "type": "string",
        "default": "time",
        "enum": ["off", "time", "time_bert"]
      },
      "time_window_seconds": {
        "description": "时间窗口（秒）：同一用户连续消息在此间隔内会被拼接",
        "type": "float",
        "default": 3.0
      },
      "semantic_min_length": {
        "description": "短于此长度的消息，在 time_bert 模式下会触发 L2 语义完整性判断",
        "type": "int",
        "default": 20
      },
      "max_fragments": {
        "description": "单次防抖最多拼接多少条连续消息",
        "type": "int",
        "default": 10
      },
      "merge_separator": {
        "description": "消息拼接分隔符",
        "type": "string",
        "default": "\n"
      },
      "command_prefixes": {
        "description": "指令前缀；命中这些前缀的消息会跳过防抖",
        "type": "list",
        "default": ["/", "#"],
        "items": {
          "type": "string"
        }
      },
      "enable_forward_analysis": {
        "description": "启用合并转发/引用消息分析（仅 aiocqhttp 平台）",
        "type": "bool",
        "default": true
      },
      "enable_typing_detection": {
        "description": "启用输入状态感知（NapCat 等支持 input_status 的平台）",
        "type": "bool",
        "default": true
      },
      "max_typing_wait": {
        "description": "输入状态感知最大等待秒数（超时保护）",
        "type": "float",
        "default": 60.0
      }
    }
  },
  "Topic_Settings": {
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用话题路由（解决群聊多话题并发问题）",
        "type": "bool",
        "default": true
      },
      "similarity_threshold": {
        "description": "话题相似度阈值（0~1），低于此值创建新话题线程",
        "type": "float",
        "default": 0.75
      },
      "thread_ttl_minutes": {
        "description": "话题线程存活时间（分钟），超时后自动归档",
        "type": "int",
        "default": 30
      },
      "max_threads_per_group": {
        "description": "单个群同时保留的活跃线程上限",
        "type": "int",
        "default": 10
      },
      "summary_interval": {
        "description": "线程每累计 N 条消息刷新一次摘要",
        "type": "int",
        "default": 20
      },
      "fast_model_provider_id": {
        "description": "线程摘要专用 Provider；留空时使用全局快速模型",
        "type": "string",
        "default": "",
        "_special": "select_provider"
      },
      "centroid_ema_alpha": {
        "description": "线程质心指数移动平均 alpha（0=不更新, 1=完全替换）",
        "type": "float",
        "default": 0.1
      }
    }
  },
  "GroupPersona_Settings": {
    "type": "object",
    "items": {
      "batch_learning_threshold": {
        "description": "群画像与每群人格学习触发阈值（消息条数）",
        "type": "int",
        "default": 200
      },
      "max_history_versions": {
        "description": "群画像 learned_prompt 历史版本保留数量",
        "type": "int",
        "default": 10
      }
    }
  },
  "Emotion_Settings": {
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用情绪引擎",
        "type": "bool",
        "default": true
      },
      "sensitivity": {
        "description": "情绪敏感度（0.0=极稳定, 1.0=极善变）",
        "type": "float",
        "default": 0.5
      },
      "initial_mood": {
        "description": "群组初始情绪标签",
        "type": "string",
        "default": "neutral"
      },
      "decay_hours": {
        "description": "情绪自然衰减回 neutral 的小时数",
        "type": "int",
        "default": 24
      }
    }
  },
  "Jargon_Settings": {
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用黑话统计",
        "type": "bool",
        "default": true
      },
      "min_frequency": {
        "description": "黑话最低出现次数",
        "type": "int",
        "default": 5
      },
      "batch_infer_size": {
        "description": "每次批量推断黑话含义的词数",
        "type": "int",
        "default": 20
      },
      "flush_threshold": {
        "description": "每个群累计多少个词后自动落库",
        "type": "int",
        "default": 500
      }
    }
  },
  "Database_Settings": {
    "type": "object",
    "items": {
      "dsn": {
        "description": "可选 PostgreSQL DSN 覆盖项；留空时使用下方主机/端口/账号配置",
        "type": "string",
        "default": ""
      },
      "host": {
        "description": "PostgreSQL 主机名；dsn 为空时必填",
        "type": "string",
        "default": ""
      },
      "port": {
        "description": "PostgreSQL 端口",
        "type": "int",
        "default": 5432
      },
      "user": {
        "description": "PostgreSQL 用户名；dsn 为空时必填",
        "type": "string",
        "default": ""
      },
      "password": {
        "description": "PostgreSQL 密码；dsn 为空时必填",
        "type": "string",
        "default": ""
      },
      "database_name": {
        "description": "PostgreSQL 数据库名；dsn 为空时必填",
        "type": "string",
        "default": ""
      },
      "pool_size": {
        "description": "数据库连接池允许的最大总连接数",
        "type": "int",
        "default": 10
      },
      "pool_min_size": {
        "description": "数据库连接池保持的基础连接数",
        "type": "int",
        "default": 2
      },
      "echo": {
        "description": "输出 SQLAlchemy SQL 调试日志",
        "type": "bool",
        "default": false
      }
    }
  },
  "WebUI_Settings": {
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用 WebUI 管理面板",
        "type": "bool",
        "default": true
      },
      "host": {
        "description": "WebUI 监听地址；默认仅监听本机",
        "type": "string",
        "default": "127.0.0.1"
      },
      "port": {
        "description": "WebUI 端口",
        "type": "int",
        "default": 7834
      },
      "auth_token": {
        "description": "可选静态 Bearer Token；配置后所有 /api/* 请求都需要 Authorization 头",
        "type": "string",
        "default": ""
      },
      "web_token_ttl_seconds": {
        "description": "WebToken 有效期（秒）",
        "type": "int",
        "default": 600
      },
      "session_token_ttl_days": {
        "description": "SessionToken 有效期（天）",
        "type": "int",
        "default": 30
      },
      "cors_origins": {
        "description": "允许访问 WebUI API 的来源列表",
        "type": "list",
        "default": ["http://localhost:7834", "http://127.0.0.1:7834"],
        "items": {
          "type": "string"
        }
      }
    }
  },
  "Debug_Settings": {
    "type": "object",
    "items": {
      "enabled": {
        "description": "调试模式：开启后详细打印记忆检索与 RAG 检索命中的内容",
        "type": "bool",
        "default": false
      }
    }
  },
  "Model_Configuration": {
    "type": "object",
    "items": {
      "embedding_provider_id": {
        "description": "Embedding Provider ID（手动填写 AstrBot 中的 provider id，用于话题路由、消息向量与记忆检索）",
        "type": "string",
        "default": ""
      },
      "main_llm_provider_id": {
        "description": "主 LLM Provider（用于群画像学习、每群人格学习）",
        "type": "string",
        "default": "",
        "_special": "select_provider"
      },
      "fast_llm_provider_id": {
        "description": "快速 LLM Provider（用于记忆抽取、情绪/黑话/防抖/线程摘要）",
        "type": "string",
        "default": "",
        "_special": "select_provider"
      },
      "embedding_dim": {
        "description": "Embedding 向量维度（BGE-M3=1024, text-embedding-3-small=1536）",
        "type": "int",
        "default": 1024
      }
    }
  },
  "Knowledge_Settings": {
    "type": "object",
    "items": {
      "engine": {
        "description": "知识引擎：off=关闭, lightrag=LightRAG 知识图谱",
        "type": "string",
        "default": "off",
        "enum": ["off", "lightrag"]
      },
      "lightrag_working_dir": {
        "description": "LightRAG 数据存储目录",
        "type": "string",
        "default": "./lightrag_data"
      },
      "query_mode": {
        "description": "LightRAG 查询模式",
        "type": "string",
        "default": "mix",
        "enum": ["naive", "local", "global", "hybrid", "mix"]
      },
      "retrieval_only_query_preferred": {
        "description": "优先使用纯检索上下文查询模式（若当前 LightRAG 版本支持）",
        "type": "bool",
        "default": true
      },
      "min_ingestion_length": {
        "description": "知识入库最小消息长度（低于此值不入库）",
        "type": "int",
        "default": 15
      },
      "ingestion_buffer_max": {
        "description": "知识入库缓冲区最大消息数",
        "type": "int",
        "default": 10
      },
      "ingestion_cooldown": {
        "description": "批量入库冷却秒数",
        "type": "int",
        "default": 60
      },
      "warmup_active_groups_limit": {
        "description": "启动时预热 LightRAG 实例的活跃群组上限",
        "type": "int",
        "default": 100
      }
    }
  },
  "Rerank_Settings": {
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用 Reranker 重排序（需要配置 Rerank Provider）",
        "type": "bool",
        "default": false
      },
      "provider_id": {
        "description": "Rerank Provider ID（AstrBot 框架中注册的 Reranker）",
        "type": "string",
        "default": ""
      },
      "top_k": {
        "description": "Rerank 后保留的 Top K 结果数",
        "type": "int",
        "default": 5
      }
    }
  },
  "PersonaBinding_Settings": {
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用独立人格绑定与每群人格学习功能",
        "type": "bool",
        "default": true
      },
      "auto_learning_enabled": {
        "description": "启用后台自动学习（消息积累达阈值后自动触发）",
        "type": "bool",
        "default": true
      },
      "auto_apply_learned_tone": {
        "description": "自动将新学习的人格版本设为活跃版本（关闭则需手动切换）",
        "type": "bool",
        "default": true
      },
      "max_tone_history_versions": {
        "description": "每个群最多保留的人格历史版本数量",
        "type": "int",
        "default": 10
      }
    }
  },
  "ReviewGate_Settings": {
    "type": "object",
    "items": {
      "enabled_for_group_persona": {
        "description": "群画像学习结果进入生效前需要审核",
        "type": "bool",
        "default": false
      },
      "enabled_for_tone": {
        "description": "每群人格学习结果进入生效前需要审核",
        "type": "bool",
        "default": false
      }
    }
  }
}
